# Copy to .env on the server:  cp .env.example .env
# Keep .env out of git (it is gitignored).

# Cloudflare Tunnel token (Zero Trust > Networks > Tunnels > your tunnel > Install connector).
# It is the long string after `--token` in the connector command Cloudflare shows you.
CLOUDFLARE_TUNNEL_TOKEN=

# Image to run. Replace `your-org` with your GitHub org/user (lowercase).
# Pin to a specific tag (e.g. :sha-1a2b3c4) for reproducible deploys, or use :latest.
WEB_IMAGE=ghcr.io/your-org/glacianav-web:latest
